# ── Runtime ──
NODE_ENV=development
PORT=3000

# ── OAuth Providers ──
# Google: https://console.cloud.google.com/apis/credentials
# Required scopes: openid email profile
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Discord: https://discord.com/developers/applications
# Required scopes: identify email
DISCORD_CLIENT_ID=your-discord-client-id
DISCORD_CLIENT_SECRET=your-discord-client-secret

# Apple (not yet implemented — reserved for future use)
# APPLE_CLIENT_ID=
# APPLE_CLIENT_SECRET=

# Base URL for OAuth redirects (no trailing slash)
# In production: https://yourdomain.com (must be https)
OAUTH_REDIRECT_BASE=http://localhost:3000

# Public app URL, used for share links / CORS if different from OAUTH_REDIRECT_BASE
APP_URL=http://localhost:3000

# Comma-separated list of allowed CORS origins in production, e.g.:
# CORS_ORIGIN=https://spritedex.app,https://www.spritedex.app
CORS_ORIGIN=http://localhost:3000

# ── Database ──
# If set, overrides the local default Postgres connection (localhost:5432).
# Example: postgres://user:password@host:5432/spritedex
# TLS is enabled automatically for any non-local host. Set PGSSL=disable to
# force plaintext (only for local/self-managed databases).
DATABASE_URL=
# PGSSL=disable

# ── Resend (email verification + password reset) ──
# https://resend.com/api-keys
RESEND_API_KEY=re_XXXXXXXXX
FROM_EMAIL=SpriteDex <quentinsavigny@protonmail.com>

# ── Push notifications ──
# Web Push VAPID keys (generated automatically on first boot if not set).
# VAPID_SUBJECT=mailto:quentinsavigny@protonmail.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
#
# Android FCM legacy server key for native Capacitor pushes.
# FCM_SERVER_KEY=
#
# iOS APNS credentials (JWT-based) for native Capacitor pushes.
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_KEY=-----BEGIN EC PRIVATE KEY-----\n...\n-----END EC PRIVATE KEY-----
# APNS_TOPIC=com.spritedex.app

# ── Scraper (optional) ──
# Path to a Chrome/Chromium binary for the fortnite.gg news scraper.
# If unset/unavailable, news scraping is skipped (app still works fully).
# CHROME_PATH=/usr/bin/chromium
